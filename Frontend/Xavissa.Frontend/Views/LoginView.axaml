<UserControl
    x:Class="Xavissa.Frontend.Views.LoginView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Xavissa.Frontend.ViewModels"
    x:DataType="vm:LoginViewModel"
    Background="{DynamicResource BackgroundBrush}">

    <Grid x:Name="LoginLayout" ColumnDefinitions="1.1*,1.4*">
        <Border x:Name="BrandPanel" Grid.Column="0" Background="{DynamicResource PrimaryDarkBrush}">
            <Grid>
                <StackPanel VerticalAlignment="Center" Spacing="16" Margin="28">
                    <Border Width="58" Height="58" CornerRadius="14" Background="#30FFFFFF">
                        <Path Data="M4,9 L12,3 L20,9 L20,20 L15,20 L15,13 L9,13 L9,20 L4,20 Z"
                              Fill="{DynamicResource SurfaceBrush}"
                              Width="28"
                              Height="28"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Xavissa"
                               FontSize="52"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryLightBrush}" />
                    <TextBlock Text="{DynamicResource Loc.BrandDescription}"
                               TextWrapping="Wrap"
                               FontSize="16"
                               Foreground="{DynamicResource SurfaceBrush}" />

                    <StackPanel Margin="0,18,0,0" Spacing="10">
                        <Border Classes="chip" Background="#30FFFFFF" HorizontalAlignment="Left">
                            <TextBlock Text="{DynamicResource Loc.FeatureRealtime}" Foreground="White" />
                        </Border>
                        <Border Classes="chip" Background="#30FFFFFF" HorizontalAlignment="Left">
                            <TextBlock Text="{DynamicResource Loc.FeatureOffline}" Foreground="White" />
                        </Border>
                        <Border Classes="chip" Background="#30FFFFFF" HorizontalAlignment="Left">
                            <TextBlock Text="{DynamicResource Loc.FeatureReceipt}" Foreground="White" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="FormPanel" Grid.Column="1" Background="{DynamicResource SurfaceBrush}">
            <ScrollViewer>
                <Border x:Name="LoginCard" Classes="panel" Width="430" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="{DynamicResource Loc.SignIn}" Classes="title" />
                        <TextBlock Text="{DynamicResource Loc.SignInSubtitle}" Classes="caption" />

                        <Border Padding="10,8"
                                CornerRadius="6"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="{DynamicResource DangerBrush}"
                                         IsVisible="{Binding IsBackendReady, Converter={StaticResource BoolInverseConverter}}" />
                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="{DynamicResource SuccessBrush}"
                                         IsVisible="{Binding IsBackendReady}" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding BackendStatusMessage}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Classes="caption"
                                               Text="{DynamicResource Loc.LoginBackendStatusHint}"
                                               TextWrapping="Wrap"
                                               IsVisible="{Binding IsBackendReady}" />
                                    <TextBlock Classes="caption"
                                               Text="{DynamicResource Loc.OfflineLoginCachedHint}"
                                               TextWrapping="Wrap"
                                               IsVisible="{Binding CanLoginOffline}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Spacing="6">
                            <TextBlock Text="{DynamicResource Loc.Username}" FontWeight="SemiBold" />
                            <TextBox x:Name="UsernameTextBox"
                                     Height="42"
                                     Watermark="{DynamicResource Loc.UsernameWatermark}"
                                     KeyDown="OnUsernameKeyDown"
                                     Text="{Binding Username, Mode=TwoWay}" />
                            <TextBlock Text="{Binding UsernameError}" Foreground="{DynamicResource DangerBrush}" Classes="caption" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="{DynamicResource Loc.Password}" FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox x:Name="PasswordTextBox"
                                         Grid.Column="0"
                                         Height="42"
                                         Watermark="{DynamicResource Loc.PasswordWatermark}"
                                         PasswordChar="*"
                                         IsVisible="{Binding IsPasswordHidden}"
                                         KeyDown="OnPasswordKeyDown"
                                         Text="{Binding Password, Mode=TwoWay}" />
                                <TextBox x:Name="VisiblePasswordTextBox"
                                         Grid.Column="0"
                                         Height="42"
                                         Watermark="{DynamicResource Loc.PasswordWatermark}"
                                         IsVisible="{Binding IsPasswordVisible}"
                                         KeyDown="OnPasswordKeyDown"
                                         Text="{Binding Password, Mode=TwoWay}" />
                                <Button Grid.Column="1"
                                        MinWidth="68"
                                        Height="42"
                                        Command="{Binding TogglePasswordVisibilityCommand}"
                                        Click="OnTogglePasswordVisibilityClick"
                                        Padding="12,0">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Path Width="16"
                                              Height="16"
                                              Stretch="Uniform"
                                              Fill="{DynamicResource ForegroundBrush}"
                                              Data="M1,8 C3.2,4.2 6,2.5 10,2.5 C14,2.5 16.8,4.2 19,8 C16.8,11.8 14,13.5 10,13.5 C6,13.5 3.2,11.8 1,8 Z M10,5.25 C8.48,5.25 7.25,6.48 7.25,8 C7.25,9.52 8.48,10.75 10,10.75 C11.52,10.75 12.75,9.52 12.75,8 C12.75,6.48 11.52,5.25 10,5.25 Z" />
                                        <TextBlock Text="{Binding PasswordToggleText}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock Text="{Binding PasswordError}" Foreground="{DynamicResource DangerBrush}" Classes="caption" />
                        </StackPanel>

                        <StackPanel Spacing="6" IsVisible="{Binding IsStoreSelectionRequired}">
                            <TextBlock Text="{DynamicResource Loc.Store}" FontWeight="SemiBold" />
                            <ComboBox Height="42"
                                      ItemsSource="{Binding StoreChoices}"
                                      SelectedValue="{Binding SelectedLoginStoreId, Mode=TwoWay}"
                                      SelectedValueBinding="{Binding Id}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <Button x:Name="LoginButton"
                                Classes="primary with-icon"
                                Height="46"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverseConverter}}"
                                IsDefault="True"
                                Command="{Binding LoginCommand}">
                            <Grid Classes="button-content" ColumnDefinitions="Auto,*" ColumnSpacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Classes="icon-badge">
                                    <Path Classes="button-icon" Data="M5,12 L19,12 M13,6 L19,12 L13,18" />
                                </Border>
                                <TextBlock Grid.Column="1" Classes="button-label" Text="{DynamicResource Loc.EnterWorkspace}" />
                            </Grid>
                        </Button>

                        <StackPanel Spacing="6" IsVisible="{Binding IsBusy}">
                            <ProgressBar IsIndeterminate="True" Height="6" />
                            <TextBlock Text="{Binding BusyMessage}" Classes="caption" HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>

