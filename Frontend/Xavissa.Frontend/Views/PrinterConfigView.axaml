<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Xavissa.Frontend.ViewModels"
    x:Class="Xavissa.Frontend.Views.PrinterConfigView"
    x:DataType="vm:PrinterConfigViewModel"
    Foreground="{DynamicResource TextPrimaryBrush}"
    Background="{DynamicResource BackgroundBrush}"
    x:CompileBindings="False">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="10">
            <TextBlock Text="{DynamicResource Loc.PrinterConfiguration}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>

            <TextBlock Text="{DynamicResource Loc.ReceiptPrinterSettings}" FontWeight="SemiBold"/>
            <StackPanel x:Name="PrinterNameRow" Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{DynamicResource Loc.ReceiptPrinter}" Width="150" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding AvailablePrinters}" SelectedItem="{Binding ReceiptPrinterName}" Width="220"/>
            </StackPanel>

            <StackPanel x:Name="PaperWidthRow" Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{DynamicResource Loc.PaperWidth}" Width="150" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding PopularPaperWidths}" SelectedItem="{Binding PaperWidth}" Width="100"/>
            </StackPanel>

            <TextBlock Text="{DynamicResource Loc.HeaderText}"/>
            <TextBox x:Name="HeaderTextBox" Text="{Binding HeaderText}" AcceptsReturn="True" Height="80" Width="500" HorizontalAlignment="Stretch"/>

            <TextBlock Text="{DynamicResource Loc.FooterText}"/>
            <TextBox x:Name="FooterTextBox" Text="{Binding FooterText}" AcceptsReturn="True" Height="80" Width="500" HorizontalAlignment="Stretch"/>

            <CheckBox Content="{DynamicResource Loc.ShowDateTime}" IsChecked="{Binding ShowDateTime}" />

            <StackPanel x:Name="HeaderImageRow" Orientation="Horizontal" Spacing="10">
                <CheckBox Content="{DynamicResource Loc.UseImageInHeader}" IsChecked="{Binding UseHeaderImage}" />
                <TextBlock Text="{Binding HeaderImagePath}" Width="200" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <Button Content="{DynamicResource Loc.SelectImage}" CommandParameter="{Binding $parent[Window]}" Command="{Binding BrowseImageCommand}" Width="120" Classes="primary"/>
            </StackPanel>

            <CheckBox Content="{DynamicResource Loc.PrintImageOnReceipt}" IsChecked="{Binding PrintImageOnReceipt}" />

            <Separator Margin="0,8,0,8"/>

            <TextBlock Text="{DynamicResource Loc.LabelPrinterSettings}" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{DynamicResource Loc.LabelPrinter}" Width="150" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding AvailablePrinters}" SelectedItem="{Binding LabelPrinterName}" Width="220"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{DynamicResource Loc.LabelWidth}" Width="150" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding LabelWidthMm}" Width="120" Minimum="20" Maximum="80" Increment="1" FormatString="0.0" InnerRightContent="mm"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{DynamicResource Loc.LabelHeight}" Width="150" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding LabelHeightMm}" Width="120" Minimum="15" Maximum="80" Increment="1" FormatString="0.0" InnerRightContent="mm"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{DynamicResource Loc.LabelGap}" Width="150" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding LabelGapMm}" Width="120" Minimum="0" Maximum="10" Increment="0.5" FormatString="0.0" InnerRightContent="mm"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{DynamicResource Loc.LabelBarcodeWidth}" Width="150" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding LabelBarcodeWidthMm}" Width="120" Minimum="15" Maximum="70" Increment="1" FormatString="0.0" InnerRightContent="mm"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{DynamicResource Loc.LabelBarcodeHeight}" Width="150" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding LabelBarcodeHeightMm}" Width="120" Minimum="6" Maximum="25" Increment="0.5" FormatString="0.0" InnerRightContent="mm"/>
            </StackPanel>

            <StackPanel x:Name="ImagePositionRow" Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{DynamicResource Loc.ImagePosition}" Width="150" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding ImagePositions}" SelectedItem="{Binding ImagePosition}" Width="150"/>
            </StackPanel>

            <Button x:Name="SavePrinterButton" Content="{DynamicResource Loc.Save}" Command="{Binding SaveConfigCommand}" HorizontalAlignment="Left" Margin="0,20,0,0" Width="180" Classes="primary"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
