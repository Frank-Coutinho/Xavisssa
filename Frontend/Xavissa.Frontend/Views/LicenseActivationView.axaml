<UserControl
    x:Class="Xavissa.Frontend.Views.LicenseActivationView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Xavissa.Frontend.ViewModels"
    x:DataType="vm:LicenseActivationViewModel"
    Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Border Classes="panel" Width="430" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
            <StackPanel Spacing="16">
                <TextBlock Text="POS workspace" Classes="title" />
                <TextBlock Text="Demo and activation flows are disabled. Use a normal tenant, store, and user account to enter the workspace." Classes="caption" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
