<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Xavissa.Frontend.ViewModels"
             xmlns:views="using:Xavissa.Frontend.Views"
             x:Class="Xavissa.Frontend.Views.AppView"
             x:DataType="vm:AppViewModel">

    <ContentControl Content="{Binding CurrentView}">
        <ContentControl.DataTemplates>
            <DataTemplate DataType="vm:LoginViewModel">
                <views:LoginView/>
            </DataTemplate>

            <DataTemplate DataType="vm:MainViewModel">
                <views:MainView/>
            </DataTemplate>

            <DataTemplate DataType="vm:ManagementViewModel">
                <views:ManagementView/>
            </DataTemplate>
        </ContentControl.DataTemplates>
    </ContentControl>
</UserControl>
