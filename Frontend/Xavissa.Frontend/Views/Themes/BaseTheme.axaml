<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Default Fallback Colors -->
  <Color x:Key="PrimaryColor">#0C4E32</Color>
  <Color x:Key="PrimaryLightColor">#4F7C64</Color>
  <Color x:Key="PrimaryDarkColor">#073B25</Color>
  <Color x:Key="PrimaryHoverColor">#16603F</Color>
  <Color x:Key="PrimaryPressedColor">#073B25</Color>

  <Color x:Key="BackgroundColor">#F7F7F7</Color>
  <Color x:Key="SurfaceColor">#FFFFFF</Color>
  <Color x:Key="SurfaceAltColor">#EFEFEF</Color>
  <Color x:Key="HoverSurfaceColor">#E4EBE7</Color>
  <Color x:Key="PressedSurfaceColor">#D8E1DC</Color>
  <Color x:Key="DividerColor">#DDDDDD</Color>
  <Color x:Key="BorderColor">#DDDDDD</Color>
  <Color x:Key="BorderStrongColor">#A9B7AF</Color>

  <Color x:Key="TextPrimaryColor">#111111</Color>
  <Color x:Key="TextSecondaryColor">#2A2A2A</Color>
  <Color x:Key="TextMutedColor">#4A4A4A</Color>
  <Color x:Key="PrimaryForegroundColor">#FFFFFF</Color>
  <Color x:Key="SuccessColor">#157347</Color>
  <Color x:Key="DangerColor">#B42318</Color>
  <Color x:Key="WarningColor">#B54708</Color>
  <Color x:Key="InfoColor">#2563EB</Color>
  <Color x:Key="DisabledBackgroundColor">#E6E8E7</Color>
  <Color x:Key="DisabledTextColor">#68746E</Color>
  <Color x:Key="FocusRingColor">#0F766E</Color>
  <Color x:Key="TableRowHoverColor">#F1F6F3</Color>
  <Color x:Key="TableRowSelectedColor">#DDECE4</Color>
  <Color x:Key="SidebarBackgroundColor">#FFFFFF</Color>
  <Color x:Key="SidebarActiveBackgroundColor">#0C4E32</Color>
  <Color x:Key="SidebarHoverBackgroundColor">#E4EBE7</Color>

  <!-- Brushes (Dynamic!) -->
  <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
  <SolidColorBrush x:Key="PrimaryLightBrush" Color="{DynamicResource PrimaryLightColor}" />
  <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{DynamicResource PrimaryDarkColor}" />
  <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{DynamicResource PrimaryHoverColor}" />
  <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{DynamicResource PrimaryPressedColor}" />

  <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}" />
  <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
  <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
  <SolidColorBrush x:Key="HoverSurfaceBrush" Color="{DynamicResource HoverSurfaceColor}" />
  <SolidColorBrush x:Key="PressedSurfaceBrush" Color="{DynamicResource PressedSurfaceColor}" />
  <SolidColorBrush x:Key="DividerBrush" Color="{DynamicResource DividerColor}" />
  <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
  <SolidColorBrush x:Key="BorderStrongBrush" Color="{DynamicResource BorderStrongColor}" />

  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
  <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextMutedColor}" />
  <SolidColorBrush x:Key="ForegroundBrush" Color="{DynamicResource TextPrimaryColor}" />
  <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="{DynamicResource PrimaryForegroundColor}" />
  <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
  <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource DangerColor}" />
  <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
  <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}" />
  <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="{DynamicResource DisabledBackgroundColor}" />
  <SolidColorBrush x:Key="DisabledTextBrush" Color="{DynamicResource DisabledTextColor}" />
  <SolidColorBrush x:Key="FocusRingBrush" Color="{DynamicResource FocusRingColor}" />
  <SolidColorBrush x:Key="TableRowHoverBrush" Color="{DynamicResource TableRowHoverColor}" />
  <SolidColorBrush x:Key="TableRowSelectedBrush" Color="{DynamicResource TableRowSelectedColor}" />
  <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{DynamicResource SidebarBackgroundColor}" />
  <SolidColorBrush x:Key="SidebarActiveBackgroundBrush" Color="{DynamicResource SidebarActiveBackgroundColor}" />
  <SolidColorBrush x:Key="SidebarHoverBackgroundBrush" Color="{DynamicResource SidebarHoverBackgroundColor}" />

</ResourceDictionary>

