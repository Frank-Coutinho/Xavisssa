<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid">

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="10" />
  </Style>

  <Style Selector="Border.metric-card">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.table-card">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Border.chip">
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,3" />
  </Style>

  <Style Selector="Border.status-banner">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
  </Style>

  <Style Selector="Border.sidebar-session-panel">
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="10" />
  </Style>

  <Style Selector="Border.sidebar-dropdown-panel">
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="4" />
  </Style>

  <Style Selector="Border.management-modal">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="Button.modal-close">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Button.modal-close:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="{DynamicResource PressedSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="Button:disabled">
    <Setter Property="Opacity" Value="0.55" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryLightBrush}" />
  </Style>

  <Style Selector="Button.primary:pressed">
    <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryDarkBrush}" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
  </Style>

  <Style Selector="Button.secondary:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Button.danger">
    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
  </Style>

  <Style Selector="Button.danger:pointerover">
    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
    <Setter Property="Opacity" Value="0.9" />
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.with-icon">
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="Button.icon-only">
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Button.shell-toggle">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.shell-toggle:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
  </Style>

  <Style Selector="Button.nav-item">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="CornerRadius" Value="5" />
  </Style>

  <Style Selector="Button.nav-item:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Button.nav-item.active">
    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="Button.sidebar-nav-button:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Button.sidebar-nav-button:pressed">
    <Setter Property="Background" Value="{DynamicResource PressedSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="Button.sidebar-nav-button.active:pointerover">
    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="Button.nav-item.danger-ghost">
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
  </Style>

  <Style Selector="Button.nav-expander">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Margin" Value="0,4,4,4" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.nav-expander:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Button.sidebar-nav-expander:pressed">
    <Setter Property="Background" Value="{DynamicResource PressedSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="Button.subnav-item">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="42,0,10,0" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="Button.subnav-item:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Button.subnav-item.active">
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Button.sidebar-subnav-button:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Button.sidebar-subnav-button.active:pointerover">
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="Border.icon-badge">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="3" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Path.button-icon">
    <Setter Property="Width" Value="10" />
    <Setter Property="Height" Value="10" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="StrokeThickness" Value="1.8" />
    <Setter Property="StrokeLineCap" Value="Round" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
  </Style>

  <Style Selector="Path.nav-fill-icon">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
  </Style>

  <Style Selector="Path.nav-stroke-icon">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="StrokeThickness" Value="1.8" />
    <Setter Property="StrokeLineCap" Value="Round" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
  </Style>

  <Style Selector="TextBlock.button-label">
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button TextBlock.button-label">
    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
  </Style>

  <Style Selector="Path.muted-icon">
    <Setter Property="Width" Value="10" />
    <Setter Property="Height" Value="10" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="StrokeThickness" Value="1.8" />
    <Setter Property="StrokeLineCap" Value="Round" />
    <Setter Property="Stroke" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.title">
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.caption">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="10,7" />
  </Style>

  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10,7" />
  </Style>

  <Style Selector="ComboBox:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="ComboBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="ComboBox:dropdownopen">
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="ComboBox:disabled">
    <Setter Property="Opacity" Value="0.55" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
  </Style>

  <Style Selector="ComboBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10,8" />
  </Style>

  <Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
  </Style>

  <Style Selector="ComboBoxItem:pressed">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource PressedSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="ComboBoxItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="ComboBoxItem:selected:pointerover">
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="DatePicker">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10,7" />
  </Style>

  <Style Selector="DatePicker:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="DatePicker:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="DatePickerPresenter">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="DatePickerPresenter Button">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="DatePickerPresenter Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
  </Style>

  <Style Selector="DatePickerPresenter Button:checked">
    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="ToggleSwitch">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TabControl">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabItem">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="TabItem:pointerover">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
  </Style>

  <Style Selector="TabItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
  </Style>

  <Style Selector="TabControl.management-tabs">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="TabControl.management-tabs TabItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="Margin" Value="0,0,18,0" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="FontWeight" Value="Normal" />
  </Style>

  <Style Selector="TabControl.management-tabs TabItem:pointerover">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TabControl.management-tabs TabItem:selected">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="dg|DataGrid">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="dg|DataGridColumnHeader">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,1" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinHeight" Value="34" />
  </Style>

  <Style Selector="dg|DataGridColumnHeader:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="dg|DataGridCell">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,1" />
    <Setter Property="Padding" Value="10,8" />
  </Style>

  <Style Selector="dg|DataGridRow:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
  </Style>

  <Style Selector="dg|DataGridCell:current">
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="CheckBox.grid-selector">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="MinWidth" Value="18" />
    <Setter Property="MinHeight" Value="18" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="CheckBox.grid-selector:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="CheckBox.grid-selector:checked">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="Expander.sidebar-management-expander">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Expander.sidebar-management-expander /template/ ToggleButton#PART_ExpanderToggleButton">
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Expander.sidebar-management-expander /template/ ToggleButton#PART_ExpanderToggleButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Expander.sidebar-management-expander /template/ ToggleButton#PART_ExpanderToggleButton:checked">
    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
  </Style>

  <Style Selector="Expander.sidebar-management-expander /template/ ToggleButton#PART_ExpanderToggleButton:checked:pointerover">
    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryLightBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
  </Style>

  <Style Selector="FlyoutPresenter">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="FlyoutPresenter.sidebar-dropdown">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Border.sidebar-flyout-panel">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TextBlock.sidebar-flyout-title">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="Button.sidebar-flyout-item">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>

  <Style Selector="Button.sidebar-flyout-item:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <!-- Operational desktop refinements: compact, high-contrast, keyboard-visible. -->
  <Style Selector="Border.panel">
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="CornerRadius" Value="5" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="CornerRadius" Value="5" />
  </Style>

  <Style Selector="Border.empty-state">
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="18" />
  </Style>

  <Style Selector="Border.status-chip">
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="8,4" />
  </Style>

  <Style Selector="Border.status-chip.success">
    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
  </Style>

  <Style Selector="Border.status-chip.warning">
    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
  </Style>

  <Style Selector="Border.status-chip.danger">
    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
  </Style>

  <Style Selector="Border.status-chip.info">
    <Setter Property="BorderBrush" Value="{DynamicResource InfoBrush}" />
  </Style>

  <Style Selector="Border.skeleton">
    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="MinHeight" Value="42" />
  </Style>

  <Style Selector="TextBlock.numeric">
    <Setter Property="TextAlignment" Value="Right" />
    <Setter Property="HorizontalAlignment" Value="Right" />
  </Style>

  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
  </Style>

  <Style Selector="Button:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <Style Selector="Button:disabled">
    <Setter Property="Background" Value="{DynamicResource DisabledBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}" />
  </Style>

  <Style Selector="Button.primary:pressed">
    <Setter Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryPressedBrush}" />
  </Style>

  <Style Selector="Button.secondary:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
  </Style>

  <Style Selector="Button.ghost:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
  </Style>

  <Style Selector="Button.nav-item">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Button.nav-item:pointerover">
    <Setter Property="Background" Value="{DynamicResource SidebarHoverBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
  </Style>

  <Style Selector="Button.nav-item.active">
    <Setter Property="Background" Value="{DynamicResource SidebarActiveBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SidebarActiveBackgroundBrush}" />
  </Style>

  <Style Selector="Button.subnav-item:pointerover">
    <Setter Property="Background" Value="{DynamicResource SidebarHoverBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
  </Style>

  <Style Selector="Button.subnav-item.active">
    <Setter Property="Background" Value="{DynamicResource TableRowSelectedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <Style Selector="ComboBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <Style Selector="DatePicker:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource FocusRingBrush}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <Style Selector="TextBox:disabled">
    <Setter Property="Background" Value="{DynamicResource DisabledBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="ComboBox:disabled">
    <Setter Property="Background" Value="{DynamicResource DisabledBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="DatePicker:disabled">
    <Setter Property="Background" Value="{DynamicResource DisabledBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="dg|DataGridRow:pointerover">
    <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}" />
  </Style>

  <Style Selector="dg|DataGridRow:selected">
    <Setter Property="Background" Value="{DynamicResource TableRowSelectedBrush}" />
  </Style>

  <Style Selector="dg|DataGridCell">
    <Setter Property="MinHeight" Value="38" />
  </Style>
</Styles>
